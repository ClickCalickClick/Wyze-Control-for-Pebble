# Wyze Control for Pebble — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# --- Your Wyze credentials (required for test scripts) ---
WYZE_EMAIL=
WYZE_PASSWORD=
WYZE_API_KEY=
WYZE_KEY_ID=

# --- Optional overrides (defaults are well-known Wyze protocol constants) ---
# WYZE_X_API_KEY=RckMFKbsds5p6QY3COEXc2ABwNTYY0q18ziEiSEm

# --- Test script options ---
# WYZE_TEST_DEVICE=          # MAC address to test a specific device
# WYZE_RUN_CONTROLS=1        # Actually send control commands (default: list-only)
# WYZE_DO_TOGGLE=1           # Toggle light on/off in wyze_test.js
